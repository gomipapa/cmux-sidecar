#!/usr/bin/env zsh
# Open the current cmux workspace's cwd in code-server, in a new cmux split.
# Lazy-starts code-server if it isn't already running.
# Usage:
#   cmux-sidecar                # opens $PWD as folder
#   cmux-sidecar <path>         # opens <path> (file or dir). If file, opens parent folder + previews file.
set -euo pipefail

CODE_SERVER_URL="${CMUX_SIDECAR_URL:-${CMUX_CODE_VIEWER_URL:-http://127.0.0.1:8765}}"
CODE_SERVER_USER_DATA="${CMUX_SIDECAR_USER_DATA:-${CMUX_CODE_VIEWER_USER_DATA:-$HOME/.local/share/code-server}}"
CODE_SERVER_LOG="${CMUX_SIDECAR_LOG:-${CMUX_CODE_VIEWER_LOG:-/tmp/code-server.log}}"
CODE_SERVER_LOCK="${CMUX_SIDECAR_LOCK:-${CMUX_CODE_VIEWER_LOCK:-/tmp/code-server.start.lockdir}}"
START_TIMEOUT_S="${CMUX_SIDECAR_START_TIMEOUT:-${CMUX_CODE_VIEWER_START_TIMEOUT:-15}}"

# Extract bind-addr (host:port) from CODE_SERVER_URL so we can pass it to
# code-server explicitly when we spawn it — this prevents a stale config.yaml
# `bind-addr:` from binding to an unexpected port.
BIND_ADDR="${CODE_SERVER_URL#*://}"
BIND_ADDR="${BIND_ADDR%%/*}"

# 1) ensure code-server is up; start it lazily if not.
# Mutex via atomic mkdir (POSIX-portable; flock is not available on stock macOS).
ensure_code_server() {
  if curl -sSf -o /dev/null "$CODE_SERVER_URL/healthz" 2>/dev/null; then
    return 0
  fi
  # try to take the start lock; concurrent callers fall through to polling.
  if mkdir "$CODE_SERVER_LOCK" 2>/dev/null; then
    # we hold the lock — make sure we drop it on every exit path
    trap 'rmdir "$CODE_SERVER_LOCK" 2>/dev/null || true' EXIT INT TERM
    # double-check: another caller may have started code-server between our
    # initial healthz and acquiring the lock
    if ! curl -sSf -o /dev/null "$CODE_SERVER_URL/healthz" 2>/dev/null; then
      if ! command -v code-server > /dev/null 2>&1; then
        echo "code-server not installed. brew install code-server" >&2
        return 127
      fi
      nohup code-server --user-data-dir "$CODE_SERVER_USER_DATA" \
        --bind-addr "$BIND_ADDR" \
        >"$CODE_SERVER_LOG" 2>&1 < /dev/null &
      disown
    fi
  fi
  # poll for readiness (lock-holder and waiters both poll)
  local deadline=$(( SECONDS + START_TIMEOUT_S ))
  while (( SECONDS < deadline )); do
    if curl -sSf -o /dev/null "$CODE_SERVER_URL/healthz" 2>/dev/null; then
      return 0
    fi
    sleep 0.5
  done
  echo "code-server did not become ready within ${START_TIMEOUT_S}s; see $CODE_SERVER_LOG" >&2
  return 1
}

ensure_code_server

# 2) resolve target path
target="${1:-$PWD}"
target="${target/#\~/$HOME}"
if [[ ! -e "$target" ]]; then
  echo "path not found: $target" >&2
  exit 1
fi
target="$(cd "$(dirname "$target")" && pwd)/$(basename "$target")"

if [[ -d "$target" ]]; then
  folder="$target"
  file=""
else
  folder="$(dirname "$target")"
  file="$target"
fi

# 3) build URL (urlencode via python3)
urlencode() { python3 -c 'import sys,urllib.parse;print(urllib.parse.quote(sys.argv[1],safe=""))' "$1"; }

url="$CODE_SERVER_URL/?folder=$(urlencode "$folder")"

# 4) open in a new cmux split. If only a folder, exec straight through.
if [[ -z "$file" ]]; then
  exec cmux --json browser open-split "$url"
fi

# File was requested. URL `payload=[["gotoLine",...]]` only navigates within an
# already-open file — it does not open one. Use code-server's IPC instead
# (`--reuse-window` talks to the running instance via the user-data-dir socket).
status=0
cmux --json browser open-split "$url" || status=$?
if (( status == 0 )); then
  # Brief settle so the new WebView's websocket reaches code-server before
  # we push the open-file event. If the pane already existed this is harmless.
  sleep 0.3
  code-server --user-data-dir "$CODE_SERVER_USER_DATA" --reuse-window "$file" \
    >/dev/null 2>&1 || true
fi
exit $status
